<Window x:Class="PhotoMoveBridge.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PhotoMove Bridge"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,14">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="PhotoMove Bridge" FontSize="26" FontWeight="SemiBold" />
                <TextBlock Text="iPhone USB 내보내기 폴더를 Windows PC/외장하드로 가져와 검증" Foreground="DimGray" />
            </StackPanel>
            <TextBlock x:Name="AppStatusText"
                       DockPanel.Dock="Right"
                       VerticalAlignment="Center"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="DarkSlateGray"
                       Text="USB 가져오기 준비" />
        </DockPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="시작">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.3*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="USB 이동 순서" Grid.Column="0" Margin="0,0,14,0">
                        <StackPanel Margin="12">
                            <TextBlock Text="1. iPhone 앱에서 사진/동영상을 선택하고 USB 내보내기를 만듭니다." Margin="0,0,0,8" TextWrapping="Wrap" />
                            <TextBlock Text="2. iPhone을 USB 케이블로 이 Windows 컴퓨터에 연결합니다." Margin="0,0,0,8" TextWrapping="Wrap" />
                            <TextBlock Text="3. Apple Devices 또는 iTunes 파일 공유에서 PhotoMoveBridgeUSBExport 안의 세션 폴더를 선택합니다." Margin="0,0,0,8" TextWrapping="Wrap" />
                            <TextBlock Text="4. 저장 폴더 탭에서 PC 하드 또는 외장하드 대상 폴더를 확정합니다." Margin="0,0,0,8" TextWrapping="Wrap" />
                            <TextBlock Text="5. USB 가져오기 탭에서 세션 폴더를 가져오면 파일 크기와 SHA256으로 검증합니다." TextWrapping="Wrap" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="출시판 연결 방식" Grid.Column="1">
                        <StackPanel Margin="12">
                            <TextBlock Text="이 Windows 앱은 로컬 네트워크 서버를 열지 않습니다." Margin="0,0,0,10" TextWrapping="Wrap" />
                            <TextBlock Text="가져오기 원본은 iPhone 앱 문서의 USB 내보내기 세션 폴더입니다." Margin="0,0,0,10" TextWrapping="Wrap" />
                            <TextBlock Text="저장 대상은 사용자가 선택한 컴퓨터 하드 또는 외장하드 폴더입니다." TextWrapping="Wrap" />
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="저장 폴더">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="DriveGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              Grid.Row="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="드라이브" Binding="{Binding DriveLetter}" Width="90" />
                            <DataGridTextColumn Header="볼륨명" Binding="{Binding VolumeLabel}" Width="160" />
                            <DataGridTextColumn Header="타입" Binding="{Binding DriveType}" Width="110" />
                            <DataGridTextColumn Header="전체 용량" Binding="{Binding TotalSize}" Width="130" />
                            <DataGridTextColumn Header="남은 용량" Binding="{Binding FreeSpace}" Width="130" />
                            <DataGridTextColumn Header="파일 시스템" Binding="{Binding FileSystem}" Width="120" />
                            <DataGridCheckBoxColumn Header="준비됨" Binding="{Binding IsReady}" Width="90" />
                            <DataGridTextColumn Header="루트" Binding="{Binding RootDirectory}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <GroupBox Grid.Row="1" Header="컴퓨터 하드/외장하드 저장 대상 확정" Margin="0,14,0,0">
                        <Grid Margin="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="저장 폴더" VerticalAlignment="Center" />
                            <TextBox x:Name="TargetRootTextBox" Grid.Row="0" Grid.Column="1" />
                            <Button Grid.Row="0" Grid.Column="2" Margin="10,0,0,0" Click="BrowseTargetRoot_Click">폴더 선택</Button>

                            <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,14,0,0">
                                <Button Click="RefreshDrives_Click">드라이브 새로고침</Button>
                                <Button Click="UseSelectedDrive_Click">선택 드라이브를 저장 대상으로 사용</Button>
                                <Button Click="UseTypedTargetRoot_Click">이 폴더를 저장 대상으로 사용</Button>
                                <Button Click="RetestTarget_Click">쓰기 테스트</Button>
                            </StackPanel>

                            <TextBlock Grid.Row="2" Grid.ColumnSpan="3" x:Name="StorageStatusText"
                                       Margin="0,14,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="DimGray" />
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="USB 가져오기">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <GroupBox Header="iPhone USB 내보내기 세션 폴더" Grid.Row="0" Margin="0,0,0,14">
                        <Grid Margin="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="세션 폴더" VerticalAlignment="Center" />
                            <TextBox x:Name="UsbExportFolderTextBox" Grid.Column="1" />
                            <Button Grid.Column="2" Margin="10,0,0,0" Click="BrowseUsbExportFolder_Click">폴더 선택</Button>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="가져오기 대상" Grid.Row="1" Margin="0,0,0,14">
                        <StackPanel Margin="12">
                            <TextBlock Text="확정된 저장 대상" FontWeight="SemiBold" />
                            <TextBlock x:Name="UsbTargetSummaryText" Margin="0,4,0,12" TextWrapping="Wrap" />
                            <Button x:Name="StartUsbImportButton"
                                    HorizontalAlignment="Left"
                                    Click="StartUsbImport_Click">
                                USB 내보내기 가져오기 시작
                            </Button>
                            <TextBlock x:Name="UsbImportStatusText"
                                       Margin="0,12,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="DimGray" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="가져오기 파일" Grid.Row="2">
                        <TextBlock Margin="12"
                                   TextWrapping="Wrap"
                                   Foreground="DimGray"
                                   Text="가져오기를 시작하면 진행 탭과 결과 탭에 파일별 복사/검증 상태가 표시됩니다." />
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="진행">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="가져오기 상태" Grid.Column="0" Margin="0,0,14,0">
                        <StackPanel Margin="12">
                            <TextBlock Text="이동 방식" FontWeight="SemiBold" />
                            <TextBlock x:Name="WorkflowSummaryText" Margin="0,4,0,14" TextWrapping="Wrap" />
                            <TextBlock Text="선택된 저장 대상" FontWeight="SemiBold" />
                            <TextBlock x:Name="SelectedTargetText" Margin="0,4,0,14" TextWrapping="Wrap" />
                            <TextBlock Text="현재 파일" FontWeight="SemiBold" />
                            <TextBlock x:Name="CurrentFileText" Margin="0,4,0,8" Text="-" TextWrapping="Wrap" />
                            <ProgressBar x:Name="CurrentProgressBar" Minimum="0" Maximum="100" Height="18" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="전송 진행" Grid.Column="1">
                        <StackPanel Margin="12">
                            <UniformGrid Columns="4" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="전체" Foreground="DimGray" />
                                    <TextBlock x:Name="TotalCountText" FontSize="24" FontWeight="SemiBold" Text="0" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="성공" Foreground="DimGray" />
                                    <TextBlock x:Name="SuccessCountText" FontSize="24" FontWeight="SemiBold" Text="0" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="실패" Foreground="DimGray" />
                                    <TextBlock x:Name="FailedCountText" FontSize="24" FontWeight="SemiBold" Text="0" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="대기" Foreground="DimGray" />
                                    <TextBlock x:Name="PendingCountText" FontSize="24" FontWeight="SemiBold" Text="0" />
                                </StackPanel>
                            </UniformGrid>

                            <DataGrid x:Name="ReceivedGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      MinHeight="360">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="파일명" Binding="{Binding OriginalFilename}" Width="220" />
                                    <DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="100" />
                                    <DataGridTextColumn Header="크기" Binding="{Binding FileSize}" Width="110" />
                                    <DataGridTextColumn Header="진행률" Binding="{Binding Progress}" Width="90" />
                                    <DataGridTextColumn Header="저장 경로 / 오류" Binding="{Binding SavedPath}" Width="*" />
                                    <DataGridTextColumn Header="오류" Binding="{Binding ErrorMessage}" Width="220" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="결과">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,12">
                        <Button Click="OpenTargetFolder_Click">저장 폴더 열기</Button>
                        <Button Click="OpenLog_Click">로그 열기</Button>
                    </StackPanel>

                    <DataGrid x:Name="ResultGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="파일명" Binding="{Binding OriginalFilename}" Width="220" />
                            <DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="100" />
                            <DataGridTextColumn Header="저장 경로" Binding="{Binding SavedPath}" Width="*" />
                            <DataGridTextColumn Header="실패 사유" Binding="{Binding ErrorMessage}" Width="260" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
